# ============================================
# Configuration Service d'Ingestion GPS Navic
# ============================================
# Copiez ce fichier en .env et configurez les valeurs

# ============================================
# Configuration Django
# ============================================
DJANGO_URL=http://localhost:8000/api/track/ingest/

# ============================================
# Configuration Sécurité
# ============================================
RATE_LIMIT_PER_IP=100
RATE_LIMIT_PER_IMEI=200
MAX_CONNECTIONS=1000
MAX_PACKET_SIZE=4096
ENABLE_IMEI_WHITELIST=true
BLOCK_DURATION=300

# ============================================
# Configuration Serveur de Commandes
# ============================================
COMMAND_PORT=8080

# ============================================
# Configuration Protocole GT06
# ============================================
GT06_TCP_PORT=5027
GT06_UDP_PORT=5028
GT06_ENABLED=true

# ============================================
# Configuration Protocole GT06N
# ============================================
GT06N_TCP_PORT=5029
GT06N_UDP_PORT=5030
GT06N_ENABLED=true

# ============================================
# Configuration Protocole TK102
# ============================================
TK102_TCP_PORT=5031
TK102_UDP_PORT=5032
TK102_ENABLED=true

# ============================================
# Configuration Protocole TK103
# ============================================
TK103_TCP_PORT=5033
TK103_UDP_PORT=5034
TK103_ENABLED=true

# ============================================
# Configuration Protocole 303
# ============================================
303_TCP_PORT=5035
303_UDP_PORT=5036
303_ENABLED=true

# ============================================
# Configuration Protocole FMXXXX/TELTONIKA
# ============================================
FMXXXX_TCP_PORT=5039
FMXXXX_UDP_PORT=5040
FMXXXX_ENABLED=true

# ============================================
# Configuration Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=